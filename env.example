# Focus NFe - Configure no .env ou variáveis de ambiente
FOCUS_NFE_TOKEN_PRODUCAO=
FOCUS_NFE_TOKEN_HOMOLOGACAO=
FOCUS_NFE_AMBIENTE=homologacao
FOCUS_NFE_CNPJ=

# Prestador/Emitente - Configure conforme seu CNPJ
PRESTADOR_CNPJ=
PRESTADOR_IM=
PRESTADOR_RAZAO=
PRESTADOR_MUNICIPIO=
PRESTADOR_EMAIL=
PRESTADOR_TELEFONE=

# Configurações fiscais
ITEM_LISTA_SERVICO=
CODIGO_TRIBUTARIO_MUNICIPIO=
ALIQUOTA=
TOMADOR_MUNICIPIO=

# WooCommerce - Configure por tenant ou aqui para uso único
WOOCOMMERCE_URL=
WOOCOMMERCE_API_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
WOOCOMMERCE_WEBHOOK_SECRET=

# Vercel Postgres (obtido no painel do Vercel)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Servidor
PORT=3000
NODE_ENV=development

# Multi-tenant SaaS (registro de novos tenants)
ADMIN_SECRET=

# Stripe (produto SaaS)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
APP_URL=

# Email (Resend - para enviar token ao assinante)
RESEND_API_KEY=
EMAIL_FROM=

# Autenticação admin (painel /admin)
# Gere o hash: node scripts/generate-password-hash.js
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
