{
  "name": "wordpress-nf",
  "version": "1.0.0",
  "description": "Aplicação intermediária para emissão de NFSe/NFe com Focus NFe integrado ao WooCommerce",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "cli": "node cli.js",
    "migrate": "node -e \"require('./src/config/database').migrate()\"",
    "generate-password-hash": "node scripts/generate-password-hash.js"
  },
  "keywords": [
    "nfe",
    "nfse",
    "focusnfe",
    "woocommerce",
    "fiscal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vercel/postgres": "^0.5.1",
    "archiver": "^7.0.1",
    "axios": "^1.6.0",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^3.0.3",
    "chalk": "^4.1.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.2",
    "googleapis": "^169.0.0",
    "inquirer": "^8.2.6",
    "table": "^6.8.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xml-formatter": "^3.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "nodemonConfig": {
    "ignore": [
      "logs/*",
      ".gemini/*",
      "items.json",
      "pedidos.json",
      "data/*",
      "data/storage.json"
    ],
    "ext": "js,mjs,cjs,json"
  }
}
